# 帧造 Agent 本地环境变量示例
# 复制为 .env 后按需填写（不要提交真实 API Key）

# --- 剪映 / CapCut ---
JIANYING_EXE=F:\JianyingPro\JianyingPro.exe
JIANYING_DRAFT_DIR=C:\Users\ZHOU\AppData\Local\JianyingPro\User Data\Projects\com.lveditor.draft
VECTCUT_IS_CAPCUT_ENV=false

# --- VectCutAPI 本地服务 ---
VECTCUT_API_HOST=127.0.0.1
VECTCUT_API_PORT=9001
VECTCUT_API_DIR=vendor/VectCutAPI

# --- HyperFrames ---
HYPERFRAMES_CLI=npx hyperframes

# --- OpenClaw（需 Node >= 22.19）---
# OPENCLAW_GATEWAY_PORT=18789

# --- 模型 Provider（平台级，比赛 Demo 用）---
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o
# VLM_PROVIDER=openai
# VLM_MODEL=gpt-4o
# ASR_PROVIDER=openai
# ASR_MODEL=whisper-1

# --- 本地 ASR（可选，faster-whisper）---
# ASR_LOCAL_MODEL=base
# ASR_LOCAL_DEVICE=cpu

# --- 路径 ---
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs
WORKSPACES_DIR=workspaces
